---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { TRIPS } from '../data/trips';

const allDays = await getCollection('days');
const tripOrder = ['milan', 'dolomitas'] as const;
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="Día a día">
  <p class="muted">11 — 21 julio 2026 · Milán, Lago di Como y las Dolomitas</p>

  {tripOrder.map((tripKey) => {
    const trip = TRIPS[tripKey];
    const days = allDays
      .filter((d) => d.data.trip === tripKey)
      .sort((a, b) => a.data.tripDay - b.data.tripDay);
    return (
      <section id={tripKey} style="margin-bottom:36px;">
        <h2 style="margin-bottom:2px;">{trip.label}</h2>
        <p class="muted" style="margin-top:0;">{trip.subtitle} · {trip.dates}</p>
        <ul style="list-style:none;padding:0;">
          {days.map((d) => (
            <li style="margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid var(--border);">
              <a href={`${base}dias/${d.slug}`} style="font-weight:600;font-size:1.05rem;">
                Día {d.data.tripDay} — {d.data.location}
              </a>
              <div class="muted" style="font-size:.85rem;margin-top:2px;">
                {d.data.weekday} {d.data.date}
                {d.data.draft && ' · (borrador, aún sin escribir)'}
              </div>
            </li>
          ))}
        </ul>
      </section>
    );
  })}
</BaseLayout>
